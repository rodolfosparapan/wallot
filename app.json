{
  "expo": {
    "name": "Wallot",
    "slug": "wallot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wallot",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#041208"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wallot.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Wallot uses your camera to scan receipts.",
        "NSMicrophoneUsageDescription": "Wallot uses your microphone to record voice entries.",
        "NSPhotoLibraryUsageDescription": "Wallot accesses your photos to import receipts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#041208"
      },
      "package": "com.wallot.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Wallot uses your camera to scan receipts." }
      ],
      [
        "expo-av",
        { "microphonePermission": "Wallot uses your microphone for voice entries." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
